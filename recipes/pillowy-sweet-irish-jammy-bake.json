      "name": "Potato",
      "amount": "2 cups, peeled and grated"
    },
    {
      "name": "Whole wheat flour",
      "amount": "1 cup"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Yeast starter",
      "amount": "1 cup"
    },
    {
      "name": "Active dry yeast",
      "amount": "2 teaspoons"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "Sugar substitute",
      "amount": "1 tablespoon"
    },
    {
      "name": "Jam",
      "amount": "1 cup"
    },
    {
      "name": "Chopped nuts",
      "amount": "1/4 cup"
    },
    {
      "name": "Vanilla extract",
      "amount": "1 teaspoon"
    },
    {
      "name": "Soda water",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Mix the yeast starter with the warm water and let it sit for 10 minutes.",
    "Add the olive oil, salt, and sugar substitute to the yeast mixture and mix well.",
    "Add the grated potato, flour, and chopped nuts to the mixture and knead for 10 minutes.",
    "Form the dough into a ball and let it rise for 1 hour.",
    "Preheat the oven to 375°F (190°C).",
    "Roll out the dough into a rectangle and spread the jam over it, leaving a 1 inch border around the edges.",
    "Fold the edges of the dough over the jam and press the edges to seal.",
    "Place the dough on a baking sheet lined with parchment paper and bake for 35 minutes.",
    "Let the bread cool for 10 minutes before slicing and serving."
  ],
