{
  "title": "Peppery Norwegian Salmon Salad",
  "description": "A dense, peppery salmon salad with vine leaves, cured salmon, and a zesty mustard dressing thats sweetfree and crowdpleasing.",
  "cuisine": "Norwegian",
  "diet": [
    "gluten-free",
    "low-carb",
