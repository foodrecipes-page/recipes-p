  "ingredients": [
    {
      "name": "beets",
      "amount": "2 large",
      "notes": "peeled and diced"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "curry powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "vegetable oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the oil in a large pan over medium heat.",
    "Add the onion and cook until softened, about 5 minutes.",
    "Add the garlic and ginger and cook for 1 minute.",
    "Add the curry powder and cook for 1 minute, stirring constantly.",
    "Add the beets and cook for 5 minutes, stirring occasionally.",
    "Pour in the coconut milk and bring to a simmer.",
    "Reduce the heat to low and cook, covered, until the beets are tender, about 20 minutes.",
    "Season with salt and pepper to taste.",
    "Use a whisk to stir and break down the beets, creating a silky texture.",
    "Serve hot over rice or with naan bread."
  ],
