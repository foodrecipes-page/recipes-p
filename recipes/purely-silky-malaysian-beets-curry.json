{
  "title": "Purely Silky Malaysian Beets Curry",
  "description": "A sweet and silky Malaysian curry featuring beets, perfect for a lazy Sunday, and kosher-friendly. This dish is easy to make and delicious to eat.",
  "cuisine": "Malaysian",
  "diet": [
    "kosher",
    "vegetarian"
