{
  "title": "Peppery Crisp Egyptian Kidney Beans Bake",
  "description": "A fragrant, peppery baked kidney bean dish with a crisp pistachio topping, inspired by Egyptian flavors and designed for a paleo-friendly dinner.",
  "cuisine": "Egyptian",
  "diet": [
