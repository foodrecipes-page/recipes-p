      "amount": "1 tbsp"
    },
    {
      "name": "Sea salt",
      "amount": "1 tsp"
    },
    {
      "name": "Freshly ground black pepper",
      "amount": "1/2 tsp"
    },
    {
      "name": "Spice blend (cumin, coriander, smoked paprika)",
      "amount": "1 tsp each"
    },
    {
      "name": "Cayenne pepper",
      "amount": "1/4 tsp"
    },
    {
      "name": "Onion, diced",
      "amount": "1 medium"
    },
    {
      "name": "Red bell pepper, diced",
      "amount": "1 medium"
    },
    {
      "name": "Garlic, minced",
      "amount": "3 cloves"
    },
    {
      "name": "Cooked kidney beans",
      "amount": "2 cups"
    },
    {
      "name": "Lemon juice",
      "amount": "1 tbsp"
    },
    {
      "name": "Fresh parsley, chopped",
      "amount": "2 tbsp"
    },
    {
      "name": "Crushed pistachios",
      "amount": "2 tbsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 400°F (200°C).",
    "Heat the olive oil in a skillet over medium heat. Add the diced onion and red bell pepper, sautéing until softened, about 5 minutes.",
    "Add minced garlic and the spice blend; cook for 1 minute until fragrant.",
    "Stir in the cooked kidney beans, lemon juice, sea salt, black pepper, and cayenne pepper. Simmer for 5 minutes to let the flavors meld.",
    "Transfer the bean mixture to a lightly greased baking dish.",
    "Sprinkle the crushed pistachios evenly over the top.",
    "Bake in the preheated oven for 15–20 minutes, or until the pistachio topping is golden and crisp.",
    "Remove from oven, garnish with fresh parsley, and serve hot."
  ],
