      "name": "lamb shoulder",
      "amount": "1 1/2 pounds",
      "notes": "cut into 2-inch pieces"
    },
    {
      "name": "curry powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "infused oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "diced tomatoes",
      "amount": "1 can"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the infused oil in a large Dutch oven over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and grated ginger and cook for an additional 1 minute.",
    "Add the lamb pieces and cook until browned on all sides, about 5 minutes.",
    "Add the curry powder, salt, and black pepper, and stir to combine.",
    "Add the diced tomatoes and chicken broth, and bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 2 1/2 hours.",
    "Serve the tagine hot, garnished with fresh herbs if desired."
  ],
