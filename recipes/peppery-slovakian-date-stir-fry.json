{
  "title": "Peppery Slovakian Date Stir-fry",
  "description": "A crisp and flavorful date-night dish featuring capers, peppers, and dates in a savory sauce, perfect for vegans and vegetarians.",
  "cuisine": "Slovakian",
  "diet": [
    "jain-friendly"
  ],
