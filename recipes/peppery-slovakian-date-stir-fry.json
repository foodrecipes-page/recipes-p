      "name": "dates",
      "amount": "20 pcs",
      "notes": "pitted"
    },
    {
      "name": "bell peppers",
      "amount": "1 medium, sliced",
      "notes": "any color"
    },
    {
      "name": "green onions",
      "amount": "8-10 pcs",
      "notes": "finely chopped for garnish"
    },
    {
      "name": "dry capers",
      "amount": "1 tbsp",
      "notes": "canned or pickled"
    },
    {
      "name": "red pepper flakes",
      "amount": "1 tsp",
      "notes": "freshly ground if using dried"
    },
    {
      "name": "soy sauce",
      "amount": "2 tbsp",
      "notes": "low sodium if preferred"
    },
    {
      "name": "vegetable oil",
      "amount": "3 tbsp"
    }
  ],
  "instructions": [
    "Heat oil in a wok or large skillet over medium-high heat.",
    "Add peppers and red pepper flakes. Stir-fry for about 2 minutes until slightly softened.",
    "Add dates, soy sauce, and capers to the pan. Stir continuously for another minute.",
    "Fold in green onions just before serving."
