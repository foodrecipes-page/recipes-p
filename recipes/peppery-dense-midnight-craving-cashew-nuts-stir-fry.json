  "ingredients": [
    {
      "name": "cashew nuts",
      "amount": "1 cup"
    },
    {
      "name": "chili peppers (diced)",
      "amount": "2-3 pieces"
    },
    {
      "name": "tomato paste",
      "amount": "1 tablespoon"
    },
    {
      "name": "sesame oil",
      "amount": "1 teaspoon"
    },
    {
      "name": "soy sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "lime juice",
      "amount": "1/2 lime"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat sesame oil in a pan over medium heat.",
    "Add cashew nuts and chili peppers, stir for about 2 minutes until the cashews start to toast lightly.",
    "Pour tomato paste into the pan, stirring continuously to prevent burning. Add soy sauce and lime juice, continuing to stir well.",
    "Reduce heat to low and let simmer for another minute or two to allow flavors to meld together.",
    "Season with salt according to taste."
  ],
