{
  "title": "Peppery Dense Midnight Craving Cashew Nut Stir-Fry",
  "description": "This peppery and dense midnight craving dish features cashew nuts in a savory sauce that is perfect for snacking or as a light dinner, suitable for pescatarian diets.",
  "cuisine": "tunisian",
  "diet": [
    "pescatarian"
