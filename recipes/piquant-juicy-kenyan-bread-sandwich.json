{
  "title": "Piquant Juicy Kenyan Bread Sandwich",
  "description": "A malty, juicy, indulgent Kenyan dish featuring red wine vinegar and double-rise-bread, this sandwich is egg-free-friendly and perfect for a snack or lunch.",
  "cuisine": "Kenyan",
  "diet": [
    "vegetarian",
