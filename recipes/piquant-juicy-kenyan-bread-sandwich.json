      "name": "double-rise-bread",
      "amount": "1 loaf",
      "notes": "preferably a day-old bread"
    },
    {
      "name": "red wine vinegar",
      "amount": "2 tablespoons"
    },
    {
      "name": "mayonnaise",
      "amount": "1/4 cup"
    },
    {
      "name": "mustard",
      "amount": "1 teaspoon"
    },
    {
      "name": "cucumber",
      "amount": "1 medium",
      "notes": "sliced"
    },
    {
      "name": "tomato",
      "amount": "1 medium",
      "notes": "sliced"
    },
    {
      "name": "onion",
      "amount": "1/4 cup",
      "notes": "thinly sliced"
    },
    {
      "name": "lettuce",
      "amount": "1 cup",
      "notes": "chopped"
    },
    {
      "name": "cheese",
      "amount": "1/2 cup",
      "notes": "shredded"
    },
    {
      "name": "butter",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat a panini press or grill to 375 degrees Fahrenheit.",
    "Slice the double-rise-bread into 1-inch thick slices.",
    "Butter one side of each bread slice.",
    "In a bowl, whisk together mayonnaise, mustard, and red wine vinegar.",
    "Spread the mayonnaise mixture on the unbuttered side of each bread slice.",
    "Layer cucumber, tomato, onion, lettuce, and cheese on one bread slice.",
    "Place the other bread slice, buttered side up, on top of the filling.",
    "Place the sandwich in the panini press or grill and cook for 5 minutes or until golden brown.",
    "Let the sandwich cool for 2 minutes before serving."
  ],
