{
  "title": "Piquant Jamaican Fish Stew",
  "description": "A nostalgic Jamaican dish featuring English muffins and lardons, this pescatarian-friendly stew is a must-try for seafood lovers. It is cooked to perfection in a cataplana vessel.",
  "cuisine": "Jamaican",
  "diet": [],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "cod fillets",
      "amount": "1 pound",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "English muffins",
      "amount": "4",
      "notes": "torn into 1-inch pieces"
    },
    {
      "name": "lardons",
      "amount": "6 slices",
      "notes": "diced"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "mustard",
      "amount": "2 tablespoons",
      "notes": "whole-grain"
    },
    {
      "name": "thyme",
      "amount": "1 teaspoon",
      "notes": "dried"
    },
    {
      "name": "scotch bonnet peppers",
      "amount": "2",
      "notes": "diced"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "Render the lardons in a skillet over medium heat until crispy.",
    "Add the chopped onion to the skillet and cook until translucent.",
    "Add the minced garlic to the skillet and cook for 1 minute.",
    "Add the cod fillets to the skillet and cook until browned on all sides.",
    "Add the torn English muffins to the cataplana vessel.",
    "Add the cooked cod, onion, and garlic mixture to the vessel.",
    "Add the mustard, thyme, and scotch bonnet peppers to the vessel.",
    "Cover the vessel with a lid and bake for 20 minutes."
  ],
