  "ingredients": [
    {
      "name": "Bacon",
      "amount": "12 slices",
      "notes": "thick cut"
    },
    {
      "name": "Malt syrup",
      "amount": "1/4 cup"
    },
    {
      "name": "Lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "Olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "Garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "Fresh oregano",
      "amount": "1 tablespoon",
      "notes": "chopped"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "Black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Pineapple chunks",
      "amount": "1 cup"
    },
    {
      "name": "Bell pepper chunks",
      "amount": "1 cup"
    },
    {
      "name": "Onion chunks",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "In a small bowl, whisk together malt syrup, lemon juice, and olive oil to make the glaze.",
    "Add garlic, oregano, salt, and black pepper to the glaze and whisk until well combined.",
    "Cut the bacon slices in half and thread onto skewers, leaving a small space between each piece.",
    "Alternate threading pineapple, bell pepper, and onion chunks onto the skewers with the bacon.",
    "Brush the glaze evenly onto the bacon and vegetables.",
    "Place the skewers on a baking sheet lined with parchment paper.",
    "Bake for 20 minutes or until the bacon is crispy and golden brown.",
    "Serve hot and enjoy."
  ],
