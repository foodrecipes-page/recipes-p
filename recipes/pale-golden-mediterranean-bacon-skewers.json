{
  "title": "Pale Golden Mediterranean Bacon Skewers",
  "description": "A light Mediterranean dish featuring crispy bacon, a malty glaze, and plant-based friendly ingredients, perfect for a snack or appetizer.",
  "cuisine": "Mediterranean",
  "diet": [
    "plant-based-friendly"
  ],
