  "ingredients": [
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "red pepper flakes",
      "amount": "1 tsp"
    },
    {
      "name": "aubergine (eggplant)",
      "amount": "1 medium, diced"
    },
    {
      "name": "zucchini",
      "amount": "1 small, sliced thinly"
    },
    {
      "name": "olive pesto sauce",
      "amount": "2 tbsp"
    },
    {
      "name": "basil leaves",
      "amount": "4-6 fresh, finely chopped"
    },
    {
      "name": "garlic cloves",
      "amount": "3-4, minced"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat olive oil in a wok or large skillet over medium-high heat.",
    "Add red pepper flakes and sauté for about 30 seconds until fragrant.",
    "Add diced aubergine and cook for about 5 minutes, stirring occasionally.",
    "Add sliced zucchini and continue to cook for another 2-3 minutes until softened but still slightly crunchy.",
    "Stir in pesto sauce, basil leaves, and minced garlic. Cook for an additional minute, allowing the flavors to meld together.",
    "Taste and adjust seasoning with salt as needed.",
    "Serve hot."
  ],
