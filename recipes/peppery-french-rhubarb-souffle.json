{
  "title": "Peppery French Rhubarb Souffle",
  "description": "A kid-friendly French dessert featuring rhubarb, with a peppery and crunchy texture, made in an earthenware bowl and suitable for halal diets.",
  "cuisine": "French",
  "diet": [
    "halal"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "rhubarb",
      "amount": "2 cups",
      "notes": "fresh, cut into 1 inch pieces"
    },
    {
      "name": "granulated sugar",
      "amount": "1 cup"
    },
    {
      "name": "all purpose flour",
      "amount": "2 tablespoons"
    },
    {
      "name": "eggs",
      "amount": "4 large"
    },
    {
      "name": "milk",
      "amount": "1 cup"
    },
    {
      "name": "unsalted butter",
      "amount": "2 tablespoons",
      "notes": "melted"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, whisk together the rhubarb, granulated sugar, flour, and black pepper.",
    "In a separate bowl, whisk together the eggs, milk, and melted butter.",
    "Add the egg mixture to the rhubarb mixture and whisk until well combined.",
    "Pour the mixture into a buttered earthenware bowl.",
    "Bake for 35 minutes or until the souffle is puffed and golden brown.",
    "Remove from the oven and let cool for 10 minutes.",
    "Serve warm, garnished with additional sugar and pepper if desired."
  ],
