  "ingredients": [
    {
      "name": "egg noodles",
      "amount": "8 oz",
      "notes": "wide egg noodles work best"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tbsp"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "celery salt",
      "amount": "1 tsp"
    },
    {
      "name": "soy sauce",
      "amount": "1 tbsp"
    },
    {
      "name": "honey",
      "amount": "1 tbsp"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "green onions",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Cook the egg noodles according to package instructions and set aside.",
    "Heat the vegetable oil in a large wok or skillet over medium-high heat.",
    "Add the chopped onion and cook until translucent, about 3-4 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the cooked noodles, celery salt, soy sauce, and honey to the wok or skillet and stir-fry for 2-3 minutes.",
    "Taste and adjust the seasoning as needed.",
    "Transfer the noodle mixture to a serving platter and garnish with chopped green onions.",
    "Serve immediately and enjoy."
  ],
