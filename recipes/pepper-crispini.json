{
  "title": "Pepper Crispini",
  "description": "A nutty, crispy dish featuring pepper and other Mediterranean-friendly ingredients for a solo-dinner meal in the British style.",
  "cuisine": "British",
  "diet": [
    "vegetarian"
  ],
