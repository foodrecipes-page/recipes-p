  "ingredients": [
    {
      "name": "Pecorino Romano cheese, grated",
      "amount": "1/4 cup"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Garlic cloves, minced",
      "amount": "3"
    },
    {
      "name": "Freshly ground black pepper",
      "amount": "To taste"
    },
    {
      "name": "Chopped parsley",
      "amount": "1/4 cup"
    },
    {
      "name": "Fennel bulbs, thinly sliced crosswise",
      "amount": "2"
    },
    {
      "name": "Pitted Kalamata olives",
      "amount": "10"
    },
    {
      "name": "Olives, pitted and halved",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "In a large skillet over medium heat, sauté minced garlic in olive oil until fragrant.",
    "Add the fennel slices and cook for about 2 minutes or until lightly browned. Add the peppercorns.",
    "Stir in parsley and olives, mix well with the fennel mixture.",
    "Transfer the mixture to a baking dish lined with parchment paper.",
    "Sprinkle grated Pecorino Romano cheese evenly over the top of the mixture.",
    "Bake for 25-30 minutes or until golden brown and crispy. Let cool slightly before serving."
  ],
