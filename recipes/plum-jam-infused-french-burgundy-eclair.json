      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "preheat the oven to 400°f (200°c).",
    "prepare the cataplana by buttering it and placing it on a baking sheet.",
    "in a medium bowl, whisk together the flour, confectioners' sugar, and salt.",
    "in a large bowl, whisk together the eggs, granulated sugar, and vanilla extract.",
    "add the flour mixture to the egg mixture and whisk until smooth.",
    "add the milk and whisk until combined.",
    "fold in the plum jam.",
    "pour the batter into the prepared cataplana.",
    "bake for 25-30 minutes or until the edges are golden brown.",
    "allow the eclair to cool before serving."
  ],
