{
  "title": "Pan Seared Croatian Sausages Skewers",
  "description": "A weeknight Croatian dish featuring German sausages, pan seared to perfection with a bitter and aerated twist, low fat friendly and easy to make",
  "cuisine": "Croatian",
  "diet": [
    "low-fat"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "German sausages",
      "amount": "4",
      "notes": "preferably Knockwurst or Bratwurst"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "bell pepper",
      "amount": "1 medium",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "zucchini",
      "amount": "1 medium",
      "notes": "cut into 1 inch slices"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "garlic powder",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "beer",
      "amount": "1/4 cup",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Preheat a large skillet over medium high heat",
    "Thread the sausages, onion, bell pepper, and zucchini onto skewers",
    "In a small bowl, mix together olive oil, salt, black pepper, paprika, and garlic powder",
    "Brush the mixture onto the skewers",
    "Add the skewers to the preheated skillet and cook for 5 minutes per side",
    "If using beer, add it to the skillet and cook for an additional 2 minutes",
    "Remove the skewers from the skillet and let rest for 2 minutes",
    "Serve the skewers hot, garnished with fresh parsley if desired"
  ],
