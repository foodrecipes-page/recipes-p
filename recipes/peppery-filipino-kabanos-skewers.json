{
  "title": "Peppery Filipino Kabanos Skewers",
  "description": "A quick and flavorful Filipino dish featuring Polish kabanos, perfect for a Mediterranean-inspired snack or appetizer. This peppery and shattering dish is easy to make and can be prepared in no time.",
  "cuisine": "Filipino",
  "diet": [
    "gluten-free",
    "meat-based"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "Polish kabanos",
      "amount": "12 slices",
      "notes": "thinly sliced"
    },
    {
      "name": "bell peppers",
      "amount": "2",
      "notes": "any color, cut into 1-inch pieces"
    },
    {
      "name": "onions",
      "amount": "1",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "black pepper",
      "amount": "1 teaspoon",
      "notes": "freshly ground"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon",
      "notes": "or to taste"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons",
      "notes": "for brushing"
    },
    {
      "name": "lemon juice",
      "amount": "1 tablespoon",
      "notes": "freshly squeezed"
    }
  ],
  "instructions": [
    "Preheat a grill or grill pan to medium-high heat.",
    "Thread a slice of kabanos, a piece of bell pepper, a piece of onion, and a sprinkle of garlic onto each skewer.",
    "Brush the skewers with olive oil and season with salt and black pepper.",
    "Grill the skewers for 2-3 minutes per side, or until the kabanos is slightly charred.",
    "Serve the skewers hot with a squeeze of lemon juice.",
    "Garnish with additional black pepper and garlic if desired.",
    "Repeat the process until all ingredients are used up.",
    "Serve immediately and enjoy."
  ],
