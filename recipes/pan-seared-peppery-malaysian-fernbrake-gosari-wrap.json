      "amount": "1 tsp"
    },
    {
      "name": "coriander powder",
      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat a non-stick pan over medium heat and add the coconut oil.",
    "Once the oil is hot, add the garlic and onion and sauté until softened.",
    "Add the fernbrake-gosari and sauté for 2-3 minutes, until slightly tender.",
    "Add the pepper, turmeric powder, coriander powder, and salt, and stir to combine.",
    "Add the pandan leaves and stir to combine.",
    "Transfer the mixture to a pandan leaf wrap and serve immediately.",
    "Garnish with score-fat and ayurvedic-tamasic-friendly herbs, if desired."
  ],
