    {
      "name": "fennel bulb",
      "amount": "2 medium bulbs",
      "notes": "any color fennel works"
    },
    {
      "name": "beetroot",
      "amount": "2 medium beets",
      "notes": "cooked and peeled"
    },
    {
      "name": "carrots",
      "amount": "2 medium carrots",
      "notes": "peeled and grated"
    },
    {
      "name": "sweet potatoes",
      "amount": "1 large sweet potato",
      "notes": "peeled and diced"
    },
    {
      "name": "ferment-jang",
      "amount": "2 tablespoons",
      "notes": "store-bought or homemade"
    },
    {
      "name": "apple cider vinegar",
      "amount": "1 tablespoon",
      "notes": "adjust to taste"
    },
    {
      "name": "water",
      "amount": "4 cups",
      "notes": "any water will do"
    },
    {
      "name": "coconut oil",
      "amount": "2 tablespoons",
      "notes": "for saut\u00057ng"
    }
  ],
  "instructions": [
    "In a large pot, heat the coconut oil over medium heat.",
    "S\u00052t\u00057e the grated carrot and diced sweet potato until softened, about 5 minutes.",
    "Add the cooked and peeled beets, chopped fennel bulb, and ferment-jang to the pot.",
    "Pour in the apple cider vinegar and water, and stir to combine.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 20 minutes.",
    "Blend the soup in batches until smooth using an immersion blender or regular blender.",
    "Return the soup to the pot and add salt and pepper to taste.",
    "Serve hot, garnished with chopped fresh herbs if desired."
  ],
