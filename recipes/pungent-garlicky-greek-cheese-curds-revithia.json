{
  "title": "Pungent Garlicky Greek Cheese Curds Revithia",
  "description": "A garlicky, velvety Greek dish featuring cheese curds, perfect for a crowd, pescatarian-friendly and full of flavor, with a twist of nuka-pickle adding a tangy crunch.",
  "cuisine": "Greek",
  "diet": [
    "pescatarian"
  ],
