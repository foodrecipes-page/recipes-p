  "ingredients": [
    {
      "name": "Cheese Curds",
      "amount": "1 pound",
      "notes": "Fresh"
    },
    {
      "name": "Nuka Pickle",
      "amount": "1/2 cup",
      "notes": "Finely chopped"
    },
    {
      "name": "Garlic",
      "amount": "6 cloves",
      "notes": "Minced"
    },
    {
      "name": "Kalamata Olives",
      "amount": "1/2 cup",
      "notes": "Pitted"
    },
    {
      "name": "Fresh Parsley",
      "amount": "1/4 cup",
      "notes": "Chopped"
    },
    {
      "name": "Lemon Juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "Olive Oil",
      "amount": "1/4 cup"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "Black Pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, whisk together olive oil, lemon juice, minced garlic, salt, and black pepper.",
    "Add the cheese curds to the bowl and toss until they are well coated with the garlic mixture.",
    "Stir in the chopped nuka pickle, kalamata olives, and chopped parsley.",
    "Transfer the mixture to a 9x13 inch baking dish.",
    "Bake for 20 minutes or until the cheese is melted and bubbly.",
    "Remove from the oven and let it cool for a few minutes before serving.",
    "Serve warm and enjoy."
  ],
