  "ingredients": [
    {
      "name": "4 canned tuna cans",
      "amount": "undrained",
      "notes": "Use water-packed for a saltier flavor"
    },
    {
      "name": "1 cup chopped fresh cilantro",
      "amount": "fresh",
      "notes": null
    },
    {
      "name": "2 cloves garlic, minced",
      "amount": "minced",
      "notes": null
    },
    {
      "name": "1/4 cup lemon juice",
      "amount": "juice",
      "notes": "Use bottled for freshness"
    },
    {
      "name": "Pinch of salt",
      "amount": "pinch",
      "notes": "To taste"
    },
    {
      "name": "1 tbsp ground cumin",
      "amount": "tbsp",
      "notes": null
    },
    {
      "name": "1 tsp black pepper",
      "amount": "tsp",
      "notes": null
    },
    {
      "name": "2 cups bread crumbs",
      "amount": "undrained",
      "notes": null
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "In a large bowl, mix tuna, cilantro, garlic, lemon juice, salt, cumin, and black pepper until well combined.",
    "Fold in bread crumbs gently with your hands or using a spatula.",
    "Transfer mixture evenly into an oven-safe dish. Spread it out to form a crumbly layer.",
    "Bake for 25-30 minutes or until golden brown and heated through.",
    "Serve warm as a side dish or over rice."
  ],
