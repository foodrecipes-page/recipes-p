      "amount": "1 cup",
      "notes": "low sodium"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 300 degrees Fahrenheit.",
    "In a large bowl, whisk together olive oil, garlic, cinnamon, salt, and black pepper.",
    "Add the chicken to the bowl and toss to coat with the marinade.",
    "Heat a large Dutch oven over medium high heat and brown the chicken on all sides.",
    "Add the onion to the pot and cook until it is translucent.",
    "Add the confit tomato, lemon juice, and chicken broth to the pot and stir to combine.",
    "Cover the pot and transfer it to the preheated oven.",
    "Bake for 30 minutes or until the chicken is cooked through.",
    "Remove the pot from the oven and stir in the chopped parsley.",
    "Serve the tagine hot on a bamboo tray."
  ],
