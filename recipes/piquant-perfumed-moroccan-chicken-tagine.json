      "name": "boneless chicken thighs",
      "amount": "1 1/2 pounds",
      "notes": "cut into 2 inch pieces"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ground cinnamon",
      "amount": "2 teaspoons"
    },
    {
      "name": "confit tomato",
      "amount": "1 cup",
      "notes": "homemade or store bought"
    },
    {
      "name": "fresh lemon juice",
      "amount": "2 tablespoons"
    },
    {
