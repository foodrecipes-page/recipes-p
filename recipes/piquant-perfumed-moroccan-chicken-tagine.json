{
  "title": "Piquant Perfumed Moroccan Chicken Tagine",
  "description": "A citrusy and nostalgic Moroccan dish featuring cinnamon and confit tomato, served on a bamboo tray. This low glycemic friendly recipe is perfect for a special occasion.",
  "cuisine": "Moroccan",
  "diet": [
    "low glycemic",
