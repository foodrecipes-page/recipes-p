      "notes": "peeled and diced"
    },
    {
      "name": "dashi extract",
      "amount": "2 teaspoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "canned tomatoes",
      "amount": "1 can"
    },
    {
      "name": "italian bread",
      "amount": "1 loaf",
      "notes": "cubed"
    },
    {
      "name": "mozzarella cheese",
      "amount": "1 cup",
      "notes": "shredded"
    },
    {
      "name": "fresh basil",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees.",
    "Toss the diced swede with olive oil, salt, and black pepper on a baking sheet.",
    "Roast the swede in the oven for 20 minutes or until tender.",
    "In a large bowl, whisk together the dashi extract and canned tomatoes.",
    "Add the roasted swede, cubed italian bread, and shredded mozzarella cheese to the bowl.",
    "Toss the mixture until the bread is well coated with the tomato mixture.",
    "Stir in the chopped fresh basil.",
    "Serve the panzanella warm, garnished with additional basil if desired."
  ],
