      "name": "beets",
      "amount": "2 large",
      "notes": "peeled and chopped"
    },
    {
      "name": "lotus leaves",
      "amount": "4 large"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "feta cheese",
      "amount": "1/2 cup",
      "notes": "crumbly"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "Blanch the lotus leaves in boiling water for 30 seconds.",
    "In a bowl, mix together the chopped beets, minced garlic, olive oil, lemon juice, salt, and black pepper.",
    "Spoon the beet mixture onto the center of each lotus leaf.",
    "Top the beet mixture with crumbly feta cheese.",
    "Fold the lotus leaves over the filling to form a wrap.",
    "Place the wraps on a baking sheet and bake for 15 minutes.",
    "Serve the wraps warm and enjoy."
  ],
