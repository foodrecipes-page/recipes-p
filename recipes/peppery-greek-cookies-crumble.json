  "ingredients": [
    {
      "name": "2 cups almond flour",
      "amount": "cups"
    },
    {
      "name": "1/2 cup grated parmesan cheese",
      "amount": "cup"
    },
    {
      "name": "3 tablespoons ground black pepper",
      "amount": "tablespoons"
    },
    {
      "name": "1/2 cup honey syrup",
      "amount": "cup"
    },
    {
      "name": "4 oz vegan butter, softened",
      "amount": "oz"
    },
    {
      "name": "2 teaspoons vanilla extract",
      "amount": "teaspoons"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C). Grease a cookie sheet.",
    "In a large mixing bowl, combine almond flour and parmesan cheese. Add ground black pepper and stir well.",
    "Add softened vegan butter and honey syrup; mix until dough forms. Stir in vanilla extract.",
    "Drop spoonfuls of the mixture onto the greased cookie sheet. Bake for 12-15 minutes or until golden brown.",
    "Cool on a wire rack, then break into small crumbles to serve."
