      "name": "red lentils",
      "amount": "1 cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "Nutella",
      "amount": "2 tablespoons"
    },
    {
      "name": "berbere spice",
      "amount": "1 teaspoon"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "vegetable broth",
      "amount": "2 cups"
    },
    {
      "name": "dairy-free cheese shreds",
      "amount": "1/2 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the kazan cauldron over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Stir in the berbere spice and cook for 1 minute.",
    "Add the red lentils, vegetable broth, tomato paste, salt, and black pepper, and bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 20 minutes, or until the lentils are tender.",
    "Stir in the Nutella and cook for an additional 2 minutes.",
    "Add the dairy-free cheese shreds and stir until melted and well combined.",
    "Serve the stew hot, garnished with additional dairy-free cheese shreds if desired."
  ],
