{
  "title": "Peppery Crispy Japanese Seafood Bowl",
  "description": "A quick, peppery bowl featuring panseared frozen seafood, fresh cucumber, and a sweetspicy sauce, all served over fluffy rice.",
  "cuisine": "Japanese",
  "diet": [
    "kosher"
  ],
