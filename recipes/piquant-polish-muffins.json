{
  "title": "Piquant Polish Muffins",
  "description": "A tangy and indulgent Polish dish featuring aerated muffins, cooked in a clay pot and served on a wooden board, perfect for a low-calorie friendly snack.",
  "cuisine": "Polish",
  "diet": [
    "low-calorie",
    "vegetarian"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "all-purpose flour",
      "amount": "1 1/2 cups",
      "notes": "sifted"
    },
    {
      "name": "granulated sugar",
      "amount": "1/2 cup"
    },
    {
      "name": "baking powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "unsalted butter",
      "amount": "1/4 cup",
      "notes": "melted"
    },
    {
      "name": "large eggs",
      "amount": "2"
    },
    {
      "name": "plain yogurt",
      "amount": "1/2 cup"
    },
    {
      "name": "lemon zest",
      "amount": "1 tablespoon"
    },
    {
      "name": "fresh lemon juice",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, whisk together the flour, sugar, baking powder, and salt.",
    "In a separate bowl, whisk together the melted butter, eggs, yogurt, lemon zest, and lemon juice.",
    "Add the wet ingredients to the dry ingredients and stir until just combined.",
    "Divide the batter evenly among 6 clay pots.",
    "Place the clay pots on a wooden board and bake for 20 minutes.",
    "Remove the muffins from the oven and let them cool in the pots for 5 minutes.",
    "Transfer the muffins to a wire rack to cool completely."
  ],
