{
  "title": "Pillowy Adventurous Portuguese Tagine",
  "description": "Pungent, pillowy, adventurous Portuguese dish featuring clear honey, made with Macrobiotic friendly ingredients and cooked in a Ttukbaegi earthenware pot.",
  "cuisine": "Portuguese",
