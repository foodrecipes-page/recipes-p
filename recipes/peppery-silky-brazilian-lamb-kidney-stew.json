      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "beef broth",
      "amount": "2 cups",
      "notes": "gluten-free"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional 1 minute.",
    "Add the sliced lamb kidney and cook until browned, about 5 minutes.",
    "Add the black pepper, cumin, paprika, and salt. Cook for 1 minute.",
    "Add the beef broth and bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 1 1/2 hours.",
    "Stir in the coconut milk and continue to simmer for an additional 30 minutes.",
    "Taste and adjust the seasoning as needed.",
    "Serve hot, garnished with chopped fresh cilantro."
  ],
