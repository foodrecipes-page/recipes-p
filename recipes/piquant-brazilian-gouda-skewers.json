      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1 tsp"
    },
    {
      "name": "bamboo skewers",
      "amount": "12",
      "notes": "soaked in water for 30 minutes"
    }
  ],
  "instructions": [
    "Preheat the grill to 400 degrees Fahrenheit.",
    "Thread a piece of Gouda cheese, a sprig of parsley, a sprig of mint, a slice of red onion, and a slice of red bell pepper onto each bamboo skewer.",
    "Brush the skewers with olive oil and season with salt and black pepper.",
    "Grill the skewers for 2-3 minutes per side, or until the cheese is melted and slightly charred.",
    "Serve the skewers hot with a squeeze of lemon juice.",
    "Let the skewers cool for a few minutes before serving.",
    "Arrange the skewers on a platter and garnish with additional parsley and mint if desired.",
    "Serve immediately and enjoy."
  ],
