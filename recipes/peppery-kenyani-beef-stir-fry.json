      "name": "Beef Stock Concentrate",
      "amount": "1 packet"
    },
    {
      "name": "Water",
      "amount": "2 cups"
    },
    {
      "name": "Garlic Cloves",
      "amount": "3 cloves",
      "notes": "Chopped finely"
    },
    {
      "name": "Onion",
      "amount": "1 medium",
      "notes": "Sliced thinly"
    },
    {
      "name": "Red Chili Flakes",
      "amount": "2 teaspoons",
      "notes": "Add more to taste"
    },
    {
      "name": "Tomato Paste",
      "amount": "1 tablespoon"
    },
    {
      "name": "Thyme Leaves",
      "amount": "4-5 leaves"
    },
    {
      "name": "Olive Oil",
      "amount": "3 tablespoons"
    }
  ],
  "instructions": [
    "Combine beef stock concentrate with water in a pot and bring to a boil. Reduce heat to low.",
    "In another pan, sauté garlic and onion until fragrant, about 2 minutes.",
    "Add red chili flakes and continue cooking for an additional minute.",
    "Stir in tomato paste and thyme leaves into the beef stock mixture.",
    "Gradually pour in the contents of the second pan to avoid lumps. Bring back to a simmer.",
    "Cook until the sauce thickens, about 10 minutes.",
    "Serve hot over steamed vegetables or rice."
  ],
