      "amount": "1/4 cup"
    },
    {
      "name": "vegetable oil",
      "amount": "1 cup"
    },
    {
      "name": "chopped fresh parsley",
      "amount": "2 tbsp"
    }
  ],
  "instructions": [
    "Combine wheat flour, salt, and black pepper in a large bowl.",
    "Add eggs and water to the bowl, mixing until a dough forms.",
    "Divide the dough into 8 equal pieces and roll each into a ball.",
    "Flatten each ball into a disk shape.",
    "Cut the prosciutto into small pieces and scatter over half of each disk.",
    "Add a few pieces of onion and garlic to each disk.",
    "Fold the other half of the dough over the filling and press the edges to seal.",
    "Heat the vegetable oil in a deep frying pan to 375°F.",
    "Fry the empanadas in batches until golden brown, about 2 minutes per side."
  ],
