{
  "title": "Puffy Plump Thai Chickpeas Pad Thai",
  "description": "A fatty and chewy Thai dish featuring chickpeas, served in a banana leaf vessel, perfect for brunch",
  "cuisine": "Thai",
  "diet": [
    "vegetarian",
    "vegan"
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "chickpeas",
      "amount": "1 cup",
      "notes": "canned, drained, and rinsed"
    },
    {
      "name": "rice noodles",
      "amount": "1 cup",
      "notes": "cooked according to package instructions"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "tamarind paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "palm sugar",
      "amount": "1 tablespoon"
    },
    {
      "name": "soy sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "banana leaves",
      "amount": "4 large",
      "notes": "fresh or frozen, thawed"
    }
  ],
  "instructions": [
    "Heat the oil in a large skillet over medium heat",
    "Add the onion and cook until translucent, about 5 minutes",
    "Add the garlic and cook for an additional minute",
    "Add the chickpeas, tamarind paste, palm sugar, and soy sauce, and stir to combine",
    "Cook for 5 minutes, stirring frequently, until the chickpeas are coated in the sauce",
    "Add the cooked noodles to the skillet and stir to combine with the chickpea mixture",
    "Spoon the mixture onto the banana leaves, leaving a 1 inch border around the edges",
    "Fold the banana leaves over the filling to form a packet, and serve immediately"
  ],
