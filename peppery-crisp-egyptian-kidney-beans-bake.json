{
  "slug": "peppery-crisp-egyptian-kidney-beans-bake",
  "title": "Egyptian-Style Stuffed Peppers",
  "description": "A flavorful and nutritious dish made by filling bell peppers with a mixture of rice, kidney beans, and spices.",
  "cuisine": "Egyptian",
