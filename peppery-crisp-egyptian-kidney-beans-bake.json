    },
    {
      "name": "1 cup cooked white rice",
      "amount": "",
      "notes": "preferably day-old rice"
    },
    {
      "name": "1 medium onion, finely chopped",
      "amount": "",
      "notes": "peppery flavor"
    },
    {
      "name": "2 cloves garlic, minced",
      "amount": "",
      "notes": "add depth to the dish"
    },
    {
